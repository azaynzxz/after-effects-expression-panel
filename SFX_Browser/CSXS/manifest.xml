<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<ExtensionManifest Version="9.0" ExtensionBundleId="com.achmad.sfx.browser" ExtensionBundleVersion="1.0.0" ExtensionBundleName="SFX Browser"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <ExtensionList>
        <Extension Id="com.achmad.sfx.browser.panel" Version="1.0.0" />
    </ExtensionList>
    <ExecutionEnvironment>
        <HostList>
            <Host Name="PPRO" Version="[12,99]" />
        </HostList>
        <LocaleList>
            <Locale Code="All" />
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="9.0" />
        </RequiredRuntimeList>
    </ExecutionEnvironment>
    <DispatchInfoList>
        <Extension Id="com.achmad.sfx.browser.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>./client/index.html</MainPath>
                    <ScriptPath>./host/index.jsx</ScriptPath>
                    <CEFCommandLine>
                        <Parameter>--enable-nodejs</Parameter>
                        <Parameter>--allow-file-access-from-files</Parameter>
                        <Parameter>--allow-file-access</Parameter>
                    </CEFCommandLine>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>SFX Browser</Menu>
                    <Geometry>
                        <Size>
                            <Height>500</Height>
                            <Width>320</Width>
                        </Size>
                        <MaxSize>
                            <Height>800</Height>
                            <Width>500</Width>
                        </MaxSize>
                        <MinSize>
                            <Height>300</Height>
                            <Width>250</Width>
                        </MinSize>
                    </Geometry>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>
